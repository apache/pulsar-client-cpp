{
  "name": "pulsar-cpp",
  "version": "4.1.0",
  "description": "Pulsar C++ SDK",
  "dependencies": [
    {
      "name": "asio",
      "features": [
        "openssl"
      ],
      "version>=": "1.32.0"
    },
    {
      "name": "boost-accumulators",
      "version>=": "1.90.0#1"
    },
    {
      "name": "boost-format",
      "version>=": "1.90.0#1"
    },
    {
      "name": "boost-property-tree",
      "version>=": "1.90.0#1"
    },
    {
      "name": "curl",
      "default-features": false,
      "features": [
        "openssl"
      ],
      "version>=": "8.18.0#1"
    },
    {
      "name": "dlfcn-win32",
      "platform": "windows"
    },
    {
      "name": "openssl",
      "version>=": "3.6.1"
    },
    {
      "name": "protobuf",
      "version>=": "6.33.4#1"
    },
    {
      "name": "snappy",
      "version>=": "1.2.2"
    },
    {
      "name": "zlib",
      "version>=": "1.3.1"
    },
    {
      "name": "zstd",
      "version>=": "1.5.7"
    }
  ],
  "features": {
    "boost-asio": {
      "description": "Use Boost.Asio instead of standalone Asio",
      "dependencies": [
        {
          "name": "boost-asio",
          "version>=": "1.90.0#1"
        }
      ]
    },
    "perf": {
      "description": "Build Performance Tool",
      "dependencies": [
        {
          "name": "boost-program-options",
          "version>=": "1.90.0#1"
        }
      ]
    },
    "tests": {
      "description": "Build Tests",
      "dependencies": [
        {
          "name": "gtest",
          "version>=": "1.17.0"
        }
      ]
    }
  }
}
